      DTS:ThreadHint="1">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{3171E798-0F67-4BCF-B7AA-992E8E9E89DA}"
          SQLTask:SqlStatementSource="SELECT LastSuccessfulLoadDate &#xA;FROM meta.TableLoadControl &#xA;WHERE TableName = 'Customers';"
          SQLTask:ResultType="ResultSetType_SingleRow" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask">
          <SQLTask:ResultBinding
            SQLTask:ResultName="0"
            SQLTask:DtsVariableName="User::LastLoadDate" />
        </SQLTask:SqlTaskData>
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\Merge stg to int"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{0193F191-FDFE-40E5-8328-A20C90CFD377}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Merge stg to int"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{3171E798-0F67-4BCF-B7AA-992E8E9E89DA}"
          SQLTask:SqlStatementSource="&#xA;UPDATE tgt&#xA;SET &#xA;    tgt.CustomerName = src.CustomerName,&#xA;    tgt.Email = src.Email,&#xA;    tgt.Phone = src.Phone,&#xA;    tgt.ODSModifiedDate = GETDATE()&#xA;FROM int.Customers AS tgt&#xA;INNER JOIN stg.Customers AS src &#xA;    ON tgt.SourceCustomerID = src.CustomerID;&#xA;&#xA;&#xA;INSERT INTO int.Customers (SourceCustomerID, CustomerName, Email, Phone, ODSInsertDate, ODSModifiedDate)&#xA;SELECT &#xA;    src.CustomerID, &#xA;    src.CustomerName, &#xA;    src.Email, &#xA;    src.Phone, &#xA;    GETDATE(), &#xA;    GETDATE()&#xA;FROM stg.Customers AS src&#xA;WHERE NOT EXISTS (&#xA;    SELECT 1 FROM int.Customers AS tgt &#xA;    WHERE tgt.SourceCustomerID = src.CustomerID&#xA;);" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\Set Current Load Date"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{B51EDF82-70FD-4767-9CC3-2CF1B7D302B8}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Set Current Load Date"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="1">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{3171E798-0F67-4BCF-B7AA-992E8E9E89DA}"
          SQLTask:SqlStatementSource="IF NOT EXISTS (SELECT 1 FROM meta.TableLoadControl WHERE TableName = 'Customers')&#xA;BEGIN&#xA;    INSERT INTO meta.TableLoadControl (TableName, LastSuccessfulLoadDate)&#xA;    VALUES ('Customers', '1900-01-01');&#xA;END" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
