    <DTS:Executable
      DTS:refId="Package\Get Last load Date"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{085079e6-982d-48f8-8aa3-e72624727078}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Get Last load Date"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{3171E798-0F67-4BCF-B7AA-992E8E9E89DA}"
          SQLTask:SqlStatementSource="SELECT ISNULL(MAX(LastSuccessfulLoadDate), '1900-01-01') AS LastLoadDate&#xA;FROM meta.TableLoadControl&#xA;WHERE TableName = 'Dim_Products';"
          SQLTask:ResultType="ResultSetType_SingleRow" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask">
          <SQLTask:ResultBinding
            SQLTask:ResultName="0"
            SQLTask:DtsVariableName="User::LastLoadDate" />
        </SQLTask:SqlTaskData>
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\Merge stg to int"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{00bf4021-edd9-430a-b4cf-bfea27e5b0dc}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Merge stg to int"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{3171E798-0F67-4BCF-B7AA-992E8E9E89DA}"
          SQLTask:SqlStatementSource="&#xA;UPDATE tgt&#xA;SET &#xA;    tgt.ProductName = src.ProductName,&#xA;    tgt.Category = src.Category,&#xA;    tgt.ListPrice = src.ListPrice, &#xA;    tgt.ODSModifiedDate = GETDATE()&#xA;FROM int.Products AS tgt&#xA;INNER JOIN stg.Products AS src &#xA;    ON tgt.SourceProductID = src.ProductID;&#xA;&#xA;INSERT INTO int.Products (SourceProductID, ProductName, Category, ListPrice, ODSInsertDate, ODSModifiedDate)&#xA;SELECT &#xA;    src.ProductID, &#xA;    src.ProductName, &#xA;    src.Category, &#xA;    src.ListPrice, &#xA;    GETDATE(), &#xA;    GETDATE()&#xA;FROM stg.Products AS src&#xA;WHERE NOT EXISTS (&#xA;    SELECT 1 FROM int.Products AS tgt &#xA;    WHERE tgt.SourceProductID = src.ProductID&#xA;);" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\Set Current Load Date"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{a48eeeda-68a3-4b30-9dca-45c2eb119ca1}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Set Current Load Date"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{3171E798-0F67-4BCF-B7AA-992E8E9E89DA}"
          SQLTask:SqlStatementSource="IF NOT EXISTS (SELECT 1 FROM meta.TableLoadControl WHERE TableName = 'Dim_Products')&#xA;    INSERT INTO meta.TableLoadControl (TableName, LastSuccessfulLoadDate)&#xA;    VALUES ('Dim_Products', '1900-01-01');&#xA;&#xA;UPDATE meta.TableLoadControl&#xA;SET LastSuccessfulLoadDate = GETDATE()  &#xA;WHERE TableName = 'Dim_Products';" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
