              SQLTask:SqlStatementSource="PRINT 'Attendance table simulated load completed at ' + CONVERT(varchar, GETDATE(), 120);&#xA;&#xA;&#xA;UPDATE meta.TableLoadControl&#xA;SET &#xA;    LastSuccessfulLoadDate = GETDATE(),&#xA;    RowsProcessed = 0, &#xA;    LastRunStatus = 'Success - Simulated'&#xA;WHERE TableName = 'Attendance';&#xA;&#xA;&#xA;IF @@ROWCOUNT = 0&#xA;BEGIN&#xA;    INSERT INTO meta.TableLoadControl (TableName, LastSuccessfulLoadDate, RowsProcessed, LastRunStatus)&#xA;    VALUES ('Attendance', GETDATE(), 0, 'Success - Simulated');&#xA;END" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
